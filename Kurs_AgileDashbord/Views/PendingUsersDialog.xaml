<Window x:Class="Kurs_AgileDashbord.Views.PendingUsersDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Заявки на регистрацию"
        Height="500" Width="680"
        WindowStartupLocation="CenterOwner"
        Style="{StaticResource MaterialDesignWindow}"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Заявки на регистрацию" FontSize="20" FontWeight="Bold"
                       Foreground="{DynamicResource PrimaryHueMidBrush}"/>
            <TextBlock x:Name="SubtitleText" FontSize="13" Foreground="#888" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Список заявок -->
        <Border Grid.Row="1" CornerRadius="8"
                Background="{DynamicResource MaterialDesignCardBackground}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="PendingList" Margin="8">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="4" Padding="16" CornerRadius="8"
                                    Background="{DynamicResource MaterialDesignBackground}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Аватар -->
                                    <Border Grid.Column="0" Width="44" Height="44" CornerRadius="22"
                                            Background="{Binding AvatarColor}" Margin="0,0,12,0">
                                        <TextBlock Text="{Binding Initials}" FontWeight="Bold"
                                                   FontSize="16" Foreground="White"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>

                                    <!-- Данные -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding FullName}" FontWeight="SemiBold" FontSize="14"/>
                                        <TextBlock Text="{Binding Email}" Foreground="#888" FontSize="12"/>
                                        <TextBlock FontSize="11" Foreground="#666" Margin="0,2,0,0">
                                            <Run Text="{Binding Role}"/>
                                            <Run Text=" · Заявка от "/>
                                            <Run Text="{Binding CreatedAt, StringFormat=dd.MM.yyyy HH:mm}"/>
                                        </TextBlock>
                                    </StackPanel>

                                    <!-- Кнопки -->
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Content="Одобрить"
                                                Style="{StaticResource MaterialDesignRaisedButton}"
                                                Background="#4CAF50" Foreground="White"
                                                materialDesign:ButtonAssist.CornerRadius="6"
                                                Padding="12,6" Margin="0,0,8,0"
                                                Tag="{Binding UserID}"
                                                Click="OnApproveClick"/>
                                        <Button Content="Отклонить"
                                                Style="{StaticResource MaterialDesignRaisedButton}"
                                                Background="#FF5252" Foreground="White"
                                                materialDesign:ButtonAssist.CornerRadius="6"
                                                Padding="12,6"
                                                Tag="{Binding UserID}"
                                                Click="OnRejectClick"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Подвал -->
        <Button Grid.Row="2" Content="Закрыть"
                Style="{StaticResource MaterialDesignFlatButton}"
                HorizontalAlignment="Right" Margin="0,16,0,0"
                Click="OnCloseClick"/>
    </Grid>
</Window>
