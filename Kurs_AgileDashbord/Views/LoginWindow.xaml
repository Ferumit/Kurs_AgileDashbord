<Window x:Class="Kurs_AgileDashbord.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="AgileBoard — Вход в систему"
        Height="560" Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Style="{StaticResource MaterialDesignWindow}"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}">

    <Grid>
        <StackPanel VerticalAlignment="Center" Margin="40">
            <!-- Логотип -->
            <StackPanel HorizontalAlignment="Center" Margin="0,0,0,32">
                <materialDesign:PackIcon Kind="ViewDashboardOutline" Width="56" Height="56"
                                         Foreground="{DynamicResource PrimaryHueMidBrush}"
                                         HorizontalAlignment="Center" Margin="0,0,0,12"/>
                <TextBlock Text="AgileBoard" FontSize="28" FontWeight="Bold"
                           Foreground="{DynamicResource PrimaryHueMidBrush}" HorizontalAlignment="Center"/>
                <TextBlock Text="Управление задачами" FontSize="13" Opacity="0.5"
                           HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Email -->
            <TextBox x:Name="EmailBox"
                     materialDesign:HintAssist.Hint="Email"
                     materialDesign:TextFieldAssist.HasLeadingIcon="True"
                     materialDesign:TextFieldAssist.LeadingIcon="Email"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     FontSize="14" Margin="0,0,0,16"/>

            <!-- Пароль -->
            <PasswordBox x:Name="PasswordBox"
                         materialDesign:HintAssist.Hint="Пароль"
                         materialDesign:TextFieldAssist.HasLeadingIcon="True"
                         materialDesign:TextFieldAssist.LeadingIcon="Lock"
                         Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                         FontSize="14" Margin="0,0,0,8"/>

            <!-- Ошибка -->
            <TextBlock x:Name="ErrorText" Foreground="#EF5350" FontSize="12"
                       HorizontalAlignment="Center" Margin="0,0,0,16"
                       Visibility="Collapsed"/>

            <!-- Кнопка входа -->
            <Button Content="ВОЙТИ" FontSize="14" FontWeight="Bold"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    materialDesign:ButtonAssist.CornerRadius="8"
                    HorizontalAlignment="Stretch" Height="44"
                    Click="OnLoginClick" Margin="0,8,0,0"/>

            <!-- Подсказка -->
            <Border Background="#2D2D44" CornerRadius="8" Padding="12" Margin="0,24,0,0">
                <StackPanel>
                    <TextBlock Text="Быстрый вход:" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,8"/>
                    <Button Style="{StaticResource MaterialDesignFlatButton}" HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left" Click="OnQuickLoginAdmin" Height="32" Padding="8,0">
                        <TextBlock FontSize="11">
                            <Run Text="👑 Админ:" FontWeight="Bold"/>
                            <Run Text=" ivanov@company.kz / admin123" Foreground="#CDDC39"/>
                        </TextBlock>
                    </Button>
                    <Button Style="{StaticResource MaterialDesignFlatButton}" HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left" Click="OnQuickLoginUser" Height="32" Padding="8,0">
                        <TextBlock FontSize="11">
                            <Run Text="👤 Пользователь:" FontWeight="Bold"/>
                            <Run Text=" petrova@company.kz / user123" Foreground="#81D4FA"/>
                        </TextBlock>
                    </Button>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Window>
