<Window x:Class="Kurs_AgileDashbord.Views.TaskDetailDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Детали задачи"
        Height="550" Width="550"
        WindowStartupLocation="CenterOwner"
        Style="{StaticResource MaterialDesignWindow}"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">
            <!-- Заголовок -->
            <DockPanel Margin="0,0,0,16">
                <Border CornerRadius="4" Padding="8,4" VerticalAlignment="Center"
                        x:Name="PriorityBadge">
                    <TextBlock x:Name="PriorityText" FontSize="11" Foreground="White" FontWeight="Bold"/>
                </Border>
                <Border CornerRadius="4" Padding="8,4" Margin="8,0,0,0" VerticalAlignment="Center"
                        x:Name="StatusBadge">
                    <TextBlock x:Name="StatusText" FontSize="11" Foreground="White" FontWeight="Bold"/>
                </Border>
            </DockPanel>

            <!-- Название -->
            <TextBlock x:Name="TitleBlock" FontSize="22" FontWeight="Bold" TextWrapping="Wrap" Margin="0,0,0,8"/>

            <!-- Описание -->
            <TextBlock x:Name="DescriptionBlock" FontSize="14" TextWrapping="Wrap" Opacity="0.8" Margin="0,0,0,16"/>

            <Separator Margin="0,0,0,16"/>

            <!-- Информация -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Проект:" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="ProjectBlock" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Спринт:" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="SprintBlock" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Автор:" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="AuthorBlock" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Исполнитель:" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBlock Grid.Row="3" Grid.Column="1" x:Name="ExecutorBlock" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="Создана:" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBlock Grid.Row="4" Grid.Column="1" x:Name="CreatedAtBlock" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="5" Grid.Column="0" Text="Завершена:" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBlock Grid.Row="5" Grid.Column="1" x:Name="CompletedAtBlock" Margin="0,0,0,8"/>
            </Grid>

            <Separator Margin="0,0,0,16"/>

            <!-- Комментарии -->
            <TextBlock Text="Комментарии" FontSize="16" FontWeight="Bold" Margin="0,0,0,12"/>
            <ItemsControl x:Name="CommentsPanel">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <materialDesign:Card Margin="0,0,0,8" Padding="12" Background="#2D2D44">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,4">
                                    <TextBlock Text="{Binding User.FullName}" FontWeight="SemiBold" FontSize="13"/>
                                    <TextBlock DockPanel.Dock="Right" HorizontalAlignment="Right"
                                               Text="{Binding CreatedAt, StringFormat='{}{0:dd.MM.yyyy}'}"
                                               FontSize="11" Opacity="0.5"/>
                                </DockPanel>
                                <TextBlock Text="{Binding Text}" TextWrapping="Wrap" Opacity="0.85"/>
                            </StackPanel>
                        </materialDesign:Card>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <TextBlock x:Name="NoCommentsText" Text="Нет комментариев" Opacity="0.4" FontStyle="Italic"
                       Visibility="Collapsed"/>

            <!-- Добавление комментария -->
            <Grid Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="CommentTextBox" Grid.Column="0"
                         materialDesign:HintAssist.Hint="Написать комментарий..."
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         TextWrapping="Wrap" MaxHeight="100" AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto" Margin="0,0,8,0"/>
                <Button Grid.Column="1" Content="Отправить" VerticalAlignment="Bottom"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Click="OnAddCommentClick" Height="36"/>
            </Grid>

            <Separator Margin="0,16,0,16"/>

            <!-- Кнопки снизу -->
            <DockPanel Margin="0,0,0,8">
                <!-- Кнопка удаления -->
                <Button x:Name="DeleteTaskButton" Content="Удалить задачу" 
                        Style="{StaticResource MaterialDesignFlatButton}" Foreground="#FF5252"
                        HorizontalAlignment="Left" Click="OnDeleteTaskClick"/>

                <!-- Кнопка закрыть -->
                <Button Content="Закрыть" Style="{StaticResource MaterialDesignOutlinedButton}"
                        HorizontalAlignment="Right"
                        Click="OnCloseClick"/>
            </DockPanel>
        </StackPanel>
    </ScrollViewer>
</Window>
