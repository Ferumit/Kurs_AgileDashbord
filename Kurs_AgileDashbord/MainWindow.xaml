<Window x:Class="Kurs_AgileDashbord.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:Kurs_AgileDashbord.ViewModels"
        mc:Ignorable="d"
        Title="AgileBoard — Управление задачами"
        Height="800" Width="1400"
        MinHeight="600" MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        Style="{StaticResource MaterialDesignWindow}"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}">

    <materialDesign:DialogHost Identifier="RootDialog">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ══════════ ВЕРХНЯЯ ПАНЕЛЬ (Header) ══════════ -->
            <Border Grid.Row="0" Padding="16,12"
                    Background="{DynamicResource MaterialDesignToolBarBackground}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Логотип -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="ViewDashboardOutline" Width="28" Height="28"
                                                 Foreground="{DynamicResource PrimaryHueMidBrush}" Margin="0,0,8,0"/>
                        <TextBlock Text="AgileBoard" FontSize="20" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryHueMidBrush}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Навигация -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="24,0,0,0">
                        <Button Content="Доска" Style="{StaticResource MaterialDesignFlatButton}"
                                Command="{Binding ShowKanbanCommand}" Margin="0,0,4,0"
                                Foreground="{DynamicResource MaterialDesignBody}"/>
                        <Button Content="Отчёты" Style="{StaticResource MaterialDesignFlatButton}"
                                Command="{Binding ShowReportsCommand}"
                                Foreground="{DynamicResource MaterialDesignBody}"/>
                    </StackPanel>

                    <!-- Выбор проекта -->
                    <ComboBox Grid.Column="3" Width="220" Margin="8,0"
                              materialDesign:HintAssist.Hint="Проект"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                              ItemsSource="{Binding Projects}"
                              SelectedItem="{Binding SelectedProject}"
                              DisplayMemberPath="ProjectName"/>

                    <!-- Поиск -->
                    <TextBox Grid.Column="4" Width="200" Margin="8,0"
                             materialDesign:HintAssist.Hint="Поиск задач..."
                             materialDesign:TextFieldAssist.HasLeadingIcon="True"
                             materialDesign:TextFieldAssist.LeadingIcon="Magnify"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- Обновить -->
                    <Button Grid.Column="5" Style="{StaticResource MaterialDesignIconButton}"
                            Command="{Binding RefreshDataCommand}" ToolTip="Обновить данные" Margin="4,0,0,0">
                        <materialDesign:PackIcon Kind="Refresh"/>
                    </Button>
                </Grid>
            </Border>

            <!-- ══════════ ОСНОВНОЙ КОНТЕНТ ══════════ -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ─── Боковая панель (фильтры) ─── -->
                <Border Grid.Column="0" Padding="12"
                        Background="{DynamicResource MaterialDesignCardBackground}"
                        BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="0,0,1,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <!-- Статистика -->
                            <TextBlock Text="СТАТИСТИКА" FontSize="11" FontWeight="Bold" Opacity="0.6" Margin="0,0,0,8"/>
                            
                            <materialDesign:Card Padding="12" Margin="0,0,0,8" Background="#2D2D30">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <materialDesign:PackIcon Kind="CheckboxMultipleMarkedOutline" Foreground="#42A5F5" Margin="0,0,8,0"/>
                                        <TextBlock>
                                            <Run Text="Задач: "/>
                                            <Run Text="{Binding TotalTasksCount, Mode=OneWay}" FontWeight="Bold"/>
                                        </TextBlock>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <materialDesign:PackIcon Kind="Run" Foreground="#66BB6A" Margin="0,0,8,0"/>
                                        <TextBlock>
                                            <Run Text="Спринтов: "/>
                                            <Run Text="{Binding ActiveSprintsCount, Mode=OneWay}" FontWeight="Bold"/>
                                        </TextBlock>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="AccountGroupOutline" Foreground="#FFA726" Margin="0,0,8,0"/>
                                        <TextBlock>
                                            <Run Text="Команда: "/>
                                            <Run Text="{Binding TeamMembersCount, Mode=OneWay}" FontWeight="Bold"/>
                                        </TextBlock>
                                    </StackPanel>
                                </StackPanel>
                            </materialDesign:Card>

                            <Separator Margin="0,8"/>

                            <!-- Фильтр: Спринт -->
                            <TextBlock Text="СПРИНТ" FontSize="11" FontWeight="Bold" Opacity="0.6" Margin="0,0,0,8"/>
                            <ComboBox materialDesign:HintAssist.Hint="Все спринты"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                      ItemsSource="{Binding Sprints}"
                                      SelectedItem="{Binding SelectedSprint}"
                                      DisplayMemberPath="SprintName"
                                      Margin="0,0,0,12"/>

                            <!-- Фильтр: Исполнитель -->
                            <TextBlock Text="ИСПОЛНИТЕЛЬ" FontSize="11" FontWeight="Bold" Opacity="0.6" Margin="0,0,0,8"/>
                            <ComboBox materialDesign:HintAssist.Hint="Все участники"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                      ItemsSource="{Binding Users}"
                                      SelectedItem="{Binding SelectedExecutorFilter}"
                                      DisplayMemberPath="FullName"
                                      Margin="0,0,0,12"/>

                            <!-- Кнопка сброса фильтров -->
                            <Button Content="Сбросить фильтры"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Command="{Binding ClearFiltersCommand}"
                                    HorizontalAlignment="Stretch" Margin="0,4"/>

                            <Separator Margin="0,12"/>

                            <!-- Кнопка создания задачи -->
                            <Button HorizontalAlignment="Stretch"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    materialDesign:ButtonAssist.CornerRadius="8"
                                    Click="OnCreateTaskClick" Margin="0,4">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Plus" Margin="0,0,8,0"/>
                                    <TextBlock Text="Новая задача"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <!-- ─── Kanban-доска ─── -->
                <Grid Grid.Column="1" Margin="12" Visibility="{Binding CurrentView, Converter={StaticResource StringToKanbanVisibilityConverter}, ConverterParameter=Kanban, FallbackValue=Visible}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Колонка: К выполнению -->
                    <Border Grid.Column="0" Margin="4" CornerRadius="12" Padding="8"
                            Background="#1E1E2E">
                        <DockPanel>
                            <Border DockPanel.Dock="Top" CornerRadius="8" Padding="12,8" Margin="0,0,0,8"
                                    Background="#78909C">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="К выполнению" FontWeight="Bold" FontSize="14" Foreground="White"/>
                                    <Border Background="#50FFFFFF" CornerRadius="10" Padding="6,2" Margin="8,0,0,0">
                                        <TextBlock Text="{Binding ToDoTasks.Count}" FontSize="12" Foreground="White" FontWeight="Bold"/>
                                    </Border>
                                </StackPanel>
                            </Border>
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding ToDoTasks}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <materialDesign:Card Margin="0,0,0,8" Padding="12"
                                                                 Background="#2D2D44" materialDesign:ElevationAssist.Elevation="Dp2"
                                                                 Cursor="Hand" MouseLeftButtonUp="OnTaskCardClick">
                                                <StackPanel>
                                                    <!-- Приоритет + Проект -->
                                                    <DockPanel Margin="0,0,0,6">
                                                        <Border CornerRadius="4" Padding="6,2"
                                                                Background="{Binding Priority, Converter={StaticResource PriorityToColorConverter}}">
                                                            <TextBlock Text="{Binding PriorityDisplayName}" FontSize="10" Foreground="White" FontWeight="Bold"/>
                                                        </Border>
                                                        <TextBlock DockPanel.Dock="Right" Text="{Binding Project.ProjectCode}"
                                                                   FontSize="10" Opacity="0.5" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                                    </DockPanel>
                                                    <!-- Название -->
                                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="13"
                                                               TextWrapping="Wrap" Margin="0,0,0,6"/>
                                                    <!-- Исполнитель -->
                                                    <DockPanel>
                                                        <Border Width="24" Height="24" CornerRadius="12"
                                                                Background="{Binding Executor.AvatarColor, Converter={StaticResource HexToColorBrushConverter}, FallbackValue=#555}"
                                                                Visibility="{Binding Executor, Converter={StaticResource NullToVisibilityConverter}}">
                                                            <TextBlock Text="{Binding Executor.Initials}" FontSize="10"
                                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                       Foreground="White" FontWeight="Bold"/>
                                                        </Border>
                                                        <TextBlock Text="{Binding Executor.FullName, FallbackValue='Не назначен'}"
                                                                   FontSize="11" Opacity="0.7" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                                        <!-- Кнопка перемещения -->
                                                        <Button DockPanel.Dock="Right" HorizontalAlignment="Right"
                                                                Style="{StaticResource MaterialDesignIconForegroundButton}"
                                                                Command="{Binding DataContext.MoveTaskStatusCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding}" ToolTip="Переместить →" Width="28" Height="28">
                                                            <materialDesign:PackIcon Kind="ArrowRight" Width="16" Height="16"/>
                                                        </Button>
                                                    </DockPanel>
                                                </StackPanel>
                                            </materialDesign:Card>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>

                    <!-- Колонка: В работе -->
                    <Border Grid.Column="1" Margin="4" CornerRadius="12" Padding="8"
                            Background="#1E1E2E">
                        <DockPanel>
                            <Border DockPanel.Dock="Top" CornerRadius="8" Padding="12,8" Margin="0,0,0,8"
                                    Background="#42A5F5">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="В работе" FontWeight="Bold" FontSize="14" Foreground="White"/>
                                    <Border Background="#50FFFFFF" CornerRadius="10" Padding="6,2" Margin="8,0,0,0">
                                        <TextBlock Text="{Binding InProgressTasks.Count}" FontSize="12" Foreground="White" FontWeight="Bold"/>
                                    </Border>
                                </StackPanel>
                            </Border>
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding InProgressTasks}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <materialDesign:Card Margin="0,0,0,8" Padding="12"
                                                                 Background="#2D2D44" materialDesign:ElevationAssist.Elevation="Dp2"
                                                                 Cursor="Hand" MouseLeftButtonUp="OnTaskCardClick">
                                                <StackPanel>
                                                    <DockPanel Margin="0,0,0,6">
                                                        <Border CornerRadius="4" Padding="6,2"
                                                                Background="{Binding Priority, Converter={StaticResource PriorityToColorConverter}}">
                                                            <TextBlock Text="{Binding PriorityDisplayName}" FontSize="10" Foreground="White" FontWeight="Bold"/>
                                                        </Border>
                                                        <TextBlock DockPanel.Dock="Right" Text="{Binding Project.ProjectCode}"
                                                                   FontSize="10" Opacity="0.5" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                                    </DockPanel>
                                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="13"
                                                               TextWrapping="Wrap" Margin="0,0,0,6"/>
                                                    <DockPanel>
                                                        <Border Width="24" Height="24" CornerRadius="12"
                                                                Background="{Binding Executor.AvatarColor, Converter={StaticResource HexToColorBrushConverter}, FallbackValue=#555}"
                                                                Visibility="{Binding Executor, Converter={StaticResource NullToVisibilityConverter}}">
                                                            <TextBlock Text="{Binding Executor.Initials}" FontSize="10"
                                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                       Foreground="White" FontWeight="Bold"/>
                                                        </Border>
                                                        <TextBlock Text="{Binding Executor.FullName, FallbackValue='Не назначен'}"
                                                                   FontSize="11" Opacity="0.7" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                                        <Button DockPanel.Dock="Right" HorizontalAlignment="Right"
                                                                Style="{StaticResource MaterialDesignIconForegroundButton}"
                                                                Command="{Binding DataContext.MoveTaskStatusCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding}" ToolTip="Переместить →" Width="28" Height="28">
                                                            <materialDesign:PackIcon Kind="ArrowRight" Width="16" Height="16"/>
                                                        </Button>
                                                    </DockPanel>
                                                </StackPanel>
                                            </materialDesign:Card>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>

                    <!-- Колонка: На проверке -->
                    <Border Grid.Column="2" Margin="4" CornerRadius="12" Padding="8"
                            Background="#1E1E2E">
                        <DockPanel>
                            <Border DockPanel.Dock="Top" CornerRadius="8" Padding="12,8" Margin="0,0,0,8"
                                    Background="#FFA726">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="На проверке" FontWeight="Bold" FontSize="14" Foreground="White"/>
                                    <Border Background="#50FFFFFF" CornerRadius="10" Padding="6,2" Margin="8,0,0,0">
                                        <TextBlock Text="{Binding ReviewTasks.Count}" FontSize="12" Foreground="White" FontWeight="Bold"/>
                                    </Border>
                                </StackPanel>
                            </Border>
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding ReviewTasks}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <materialDesign:Card Margin="0,0,0,8" Padding="12"
                                                                 Background="#2D2D44" materialDesign:ElevationAssist.Elevation="Dp2"
                                                                 Cursor="Hand" MouseLeftButtonUp="OnTaskCardClick">
                                                <StackPanel>
                                                    <DockPanel Margin="0,0,0,6">
                                                        <Border CornerRadius="4" Padding="6,2"
                                                                Background="{Binding Priority, Converter={StaticResource PriorityToColorConverter}}">
                                                            <TextBlock Text="{Binding PriorityDisplayName}" FontSize="10" Foreground="White" FontWeight="Bold"/>
                                                        </Border>
                                                        <TextBlock DockPanel.Dock="Right" Text="{Binding Project.ProjectCode}"
                                                                   FontSize="10" Opacity="0.5" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                                    </DockPanel>
                                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="13"
                                                               TextWrapping="Wrap" Margin="0,0,0,6"/>
                                                    <DockPanel>
                                                        <Border Width="24" Height="24" CornerRadius="12"
                                                                Background="{Binding Executor.AvatarColor, Converter={StaticResource HexToColorBrushConverter}, FallbackValue=#555}"
                                                                Visibility="{Binding Executor, Converter={StaticResource NullToVisibilityConverter}}">
                                                            <TextBlock Text="{Binding Executor.Initials}" FontSize="10"
                                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                       Foreground="White" FontWeight="Bold"/>
                                                        </Border>
                                                        <TextBlock Text="{Binding Executor.FullName, FallbackValue='Не назначен'}"
                                                                   FontSize="11" Opacity="0.7" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                                        <Button DockPanel.Dock="Right" HorizontalAlignment="Right"
                                                                Style="{StaticResource MaterialDesignIconForegroundButton}"
                                                                Command="{Binding DataContext.MoveTaskStatusCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding}" ToolTip="Переместить →" Width="28" Height="28">
                                                            <materialDesign:PackIcon Kind="ArrowRight" Width="16" Height="16"/>
                                                        </Button>
                                                    </DockPanel>
                                                </StackPanel>
                                            </materialDesign:Card>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>

                    <!-- Колонка: Готово -->
                    <Border Grid.Column="3" Margin="4" CornerRadius="12" Padding="8"
                            Background="#1E1E2E">
                        <DockPanel>
                            <Border DockPanel.Dock="Top" CornerRadius="8" Padding="12,8" Margin="0,0,0,8"
                                    Background="#66BB6A">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Готово" FontWeight="Bold" FontSize="14" Foreground="White"/>
                                    <Border Background="#50FFFFFF" CornerRadius="10" Padding="6,2" Margin="8,0,0,0">
                                        <TextBlock Text="{Binding DoneTasks.Count}" FontSize="12" Foreground="White" FontWeight="Bold"/>
                                    </Border>
                                </StackPanel>
                            </Border>
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding DoneTasks}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <materialDesign:Card Margin="0,0,0,8" Padding="12"
                                                                 Background="#2D2D44" materialDesign:ElevationAssist.Elevation="Dp2"
                                                                 Cursor="Hand" MouseLeftButtonUp="OnTaskCardClick"
                                                                 Opacity="0.75">
                                                <StackPanel>
                                                    <DockPanel Margin="0,0,0,6">
                                                        <Border CornerRadius="4" Padding="6,2"
                                                                Background="{Binding Priority, Converter={StaticResource PriorityToColorConverter}}">
                                                            <TextBlock Text="{Binding PriorityDisplayName}" FontSize="10" Foreground="White" FontWeight="Bold"/>
                                                        </Border>
                                                        <TextBlock DockPanel.Dock="Right" Text="{Binding Project.ProjectCode}"
                                                                   FontSize="10" Opacity="0.5" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                                    </DockPanel>
                                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="13"
                                                               TextWrapping="Wrap" TextDecorations="Strikethrough" Margin="0,0,0,6"/>
                                                    <DockPanel>
                                                        <Border Width="24" Height="24" CornerRadius="12"
                                                                Background="{Binding Executor.AvatarColor, Converter={StaticResource HexToColorBrushConverter}, FallbackValue=#555}"
                                                                Visibility="{Binding Executor, Converter={StaticResource NullToVisibilityConverter}}">
                                                            <TextBlock Text="{Binding Executor.Initials}" FontSize="10"
                                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                       Foreground="White" FontWeight="Bold"/>
                                                        </Border>
                                                        <TextBlock Text="{Binding Executor.FullName, FallbackValue='Не назначен'}"
                                                                   FontSize="11" Opacity="0.7" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                                        <Button DockPanel.Dock="Right" HorizontalAlignment="Right"
                                                                Style="{StaticResource MaterialDesignIconForegroundButton}"
                                                                Command="{Binding DataContext.MoveTaskStatusCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding}" ToolTip="Вернуть в To Do" Width="28" Height="28">
                                                            <materialDesign:PackIcon Kind="Undo" Width="16" Height="16"/>
                                                        </Button>
                                                    </DockPanel>
                                                </StackPanel>
                                            </materialDesign:Card>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>
                </Grid>

                <!-- ─── Вкладка Отчёты ─── -->
                <ScrollViewer Grid.Column="1" Margin="12" VerticalScrollBarVisibility="Auto"
                              Visibility="{Binding CurrentView, Converter={StaticResource StringToKanbanVisibilityConverter}, ConverterParameter=Reports, FallbackValue=Collapsed}">
                    <StackPanel>
                        
                        <!-- Отчёт по спринтам -->
                        <TextBlock Text="Отчёт по спринтам" FontSize="20" FontWeight="Bold" Margin="0,0,0,12"
                                   Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                        
                        <ItemsControl ItemsSource="{Binding SprintReports}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <materialDesign:Card Margin="0,0,0,8" Padding="16" Background="#2D2D44">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <DockPanel Margin="0,0,0,4">
                                                    <TextBlock Text="{Binding SprintName}" FontWeight="Bold" FontSize="15"/>
                                                    <TextBlock Text="{Binding StatusLabel}" FontSize="12" Margin="12,0,0,0" VerticalAlignment="Center"/>
                                                </DockPanel>
                                                <TextBlock Text="{Binding DateRange}" FontSize="12" Opacity="0.5" Margin="0,0,0,8"/>
                                                <StackPanel Orientation="Horizontal">
                                                    <Border CornerRadius="4" Padding="8,3" Background="#78909C" Margin="0,0,6,0">
                                                        <TextBlock FontSize="11" Foreground="White">
                                                            <Run Text="К выполнению: "/><Run Text="{Binding ToDo, Mode=OneWay}" FontWeight="Bold"/>
                                                        </TextBlock>
                                                    </Border>
                                                    <Border CornerRadius="4" Padding="8,3" Background="#42A5F5" Margin="0,0,6,0">
                                                        <TextBlock FontSize="11" Foreground="White">
                                                            <Run Text="В работе: "/><Run Text="{Binding InProgress, Mode=OneWay}" FontWeight="Bold"/>
                                                        </TextBlock>
                                                    </Border>
                                                    <Border CornerRadius="4" Padding="8,3" Background="#FFA726" Margin="0,0,6,0">
                                                        <TextBlock FontSize="11" Foreground="White">
                                                            <Run Text="На проверке: "/><Run Text="{Binding InReview, Mode=OneWay}" FontWeight="Bold"/>
                                                        </TextBlock>
                                                    </Border>
                                                    <Border CornerRadius="4" Padding="8,3" Background="#66BB6A" Margin="0,0,6,0">
                                                        <TextBlock FontSize="11" Foreground="White">
                                                            <Run Text="Готово: "/><Run Text="{Binding Done, Mode=OneWay}" FontWeight="Bold"/>
                                                        </TextBlock>
                                                    </Border>
                                                </StackPanel>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="16,0,0,0">
                                                <TextBlock FontSize="28" FontWeight="Bold" HorizontalAlignment="Center"
                                                           Foreground="{DynamicResource PrimaryHueMidBrush}">
                                                    <Run Text="{Binding CompletionPercent, Mode=OneWay}"/><Run Text="%"/>
                                                </TextBlock>
                                                <TextBlock Text="выполнено" FontSize="11" Opacity="0.5" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Grid>
                                    </materialDesign:Card>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Продуктивность команды -->
                        <TextBlock Text="Продуктивность команды" FontSize="20" FontWeight="Bold" Margin="0,24,0,12"
                                   Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                        
                        <ItemsControl ItemsSource="{Binding UserProductivity}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <materialDesign:Card Width="220" Margin="0,0,8,8" Padding="16" Background="#2D2D44">
                                        <StackPanel>
                                            <DockPanel Margin="0,0,0,8">
                                                <Border Width="36" Height="36" CornerRadius="18"
                                                        Background="{Binding AvatarColor, Converter={StaticResource HexToColorBrushConverter}}">
                                                    <TextBlock Text="{Binding Initials}" FontSize="14"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               Foreground="White" FontWeight="Bold"/>
                                                </Border>
                                                <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding FullName}" FontWeight="SemiBold" FontSize="13"/>
                                                    <TextBlock Text="{Binding Role}" FontSize="11" Opacity="0.5"/>
                                                </StackPanel>
                                            </DockPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                <TextBlock FontSize="12" Opacity="0.7">
                                                    <Run Text="Всего: "/><Run Text="{Binding TotalTasks, Mode=OneWay}" FontWeight="Bold"/>
                                                    <Run Text=" | Выполнено: "/><Run Text="{Binding CompletedTasks, Mode=OneWay}" FontWeight="Bold" Foreground="#66BB6A"/>
                                                </TextBlock>
                                            </StackPanel>
                                            <Grid Height="6" Margin="0,4,0,0">
                                                <Border Background="#404050" CornerRadius="3"/>
                                                <ProgressBar Value="{Binding CompletionPercent, Mode=OneWay}" Maximum="100"
                                                             Foreground="#66BB6A" Background="Transparent"
                                                             Height="6"/>
                                            </Grid>
                                            <TextBlock HorizontalAlignment="Right" FontSize="12" Opacity="0.5" Margin="0,4,0,0">
                                                <Run Text="{Binding CompletionPercent, Mode=OneWay}"/><Run Text="%"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </materialDesign:Card>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>

                <!-- Загрузка -->
                <ProgressBar Grid.Column="1" IsIndeterminate="True" VerticalAlignment="Top"
                             Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </Grid>

            <!-- ══════════ СТАТУС-БАР ══════════ -->
            <Border Grid.Row="2" Padding="12,6"
                    Background="{DynamicResource MaterialDesignToolBarBackground}">
                <DockPanel>
                    <TextBlock Text="{Binding StatusBarText}" FontSize="12" Opacity="0.7" VerticalAlignment="Center"/>
                    <TextBlock DockPanel.Dock="Right" HorizontalAlignment="Right" FontSize="12" Opacity="0.5"
                               VerticalAlignment="Center">
                        <Run Text="AgileBoard v1.0 | Курсовая работа"/>
                    </TextBlock>
                </DockPanel>
            </Border>
        </Grid>
    </materialDesign:DialogHost>
</Window>
